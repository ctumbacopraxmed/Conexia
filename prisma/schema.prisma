generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  roleId    Int
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tokens    Token[]
  role      Role      @relation(fields: [roleId], references: [id])
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  isActive    Boolean      @default(true)
  deletedAt   DateTime?
  users       User[]
  permissions Permission[] @relation("RolePermissions")
}

model Permission {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  roles       Role[]  @relation("RolePermissions")
}

model Token {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
}

model autorizacionweb {
  id                          Int                      @id @default(autoincrement())
  orden_servicio              Int?                     @unique
  fecha_orden                 DateTime?                @db.Timestamp(6)
  prestador_documento_id      String?                  @db.VarChar(20)
  numero_poliza               Int?
  numero_familia              Int?
  numero_afiliado             Int?
  beneficiario_documento_id   String?                  @db.VarChar(20)
  fecha_creacion              DateTime?                @db.Timestamp(6)
  usuario_creacion_id         String?                  @db.VarChar(20)
  tipo                        String?                  @db.VarChar(2)
  clase                       String?                  @db.VarChar(11)
  fecha_pago_caja             DateTime?                @db.Date
  factura_caja                String?                  @db.VarChar(17)
  tipoatencion                String?                  @db.VarChar(15)
  orden_suit                  Int?                     @unique(map: "autorizacionweb_unique")
  estado                      Estado?
  bloqueopagoapp              Int?
  codigo_plan                 BigInt?
  tipo_documento_beneficiario String?                  @db.VarChar(9)
  autorizacionwebdetalle      autorizacionwebdetalle[]

  @@index([fecha_creacion], map: "idx_fecha_creacion")
  @@index([fecha_orden], map: "idx_fecha_orden")
  @@index([numero_poliza], map: "idx_numero_poliza")
  @@index([orden_servicio], map: "idx_orden_servicios")
}

model autorizacionwebdetalle {
  id                        Int              @id @default(autoincrement())
  autorizacionweb_id        Int?
  orden_servicio            Int?
  codigo_servicio           String?          @db.VarChar(100)
  cantidad_servicio         Int?
  codigo_diagnostico        String?          @db.VarChar(255)
  valor_ecusanitas          Decimal?         @db.Decimal(10, 2)
  valor_cubierto            Decimal?         @db.Decimal(10, 2)
  valor_copago_total        Decimal?         @db.Decimal(10, 2)
  valor_deducible           Decimal?         @db.Decimal(10, 2)
  porcentaje_cobertura      Decimal?         @db.Decimal(10, 2)
  copago_minimo             Decimal?         @db.Decimal(10, 2)
  valor_descuento           Decimal?         @db.Decimal(10, 2)
  codigo_diagnostico_origen String?          @db.VarChar(255)
  tipo_honorario            String?          @db.VarChar(5)
  prestador_prestacion      String?          @db.VarChar(13)
  codigo_financiador        String?          @db.VarChar(20)
  tipo_tecnologia           String?          @db.VarChar(3)
  autorizacionweb           autorizacionweb? @relation(fields: [autorizacionweb_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([codigo_servicio], map: "idx_codigo_servicio")
  @@index([codigo_diagnostico], map: "idx_diagnostico")
  @@index([orden_servicio], map: "idx_orden_servicio")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model plan_prueba {
  plan                    String?
  procedure               String?
  daily_limit             BigInt?
  has_limit               Boolean?
  monthly_limit           BigInt?
  weekly_limit            BigInt?
  daily_amount_limit      Float?
  weekly_amount_limit     Float?
  yearly_limit            BigInt?
  yearly_amount_limit     Float?
  monthly_amount_limit    Float?
  has_co_pay              Boolean?
  has_refund              Boolean?
  has_co_insurance        Boolean?
  co_pay_amount           Float?
  over_limit_action_id    BigInt?
  network_level_id        BigInt?
  co_insurance_percentage BigInt?
  is_applicable           Boolean?
  promotion_end_date      String?
  promotion_start_date    String?
  exempt_deductible       Boolean?
  technology_code         String?
  patient_care_type_id    BigInt?
  practice_type_id        BigInt?

  @@ignore
}

enum Estado {
  APROBADO
  PAGADO
}
